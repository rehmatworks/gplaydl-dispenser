# Server bind address
DISPENSER_ADDR=:8080

# Postgres connection (docker-compose default shown)
DATABASE_URL=postgres://dispenser:dispenser@localhost:5466/dispenser?sslmode=disable

# AES-256 key for encrypting AAS tokens at rest.
# Generate your own: openssl rand -hex 32
DISPENSER_ENCRYPTION_KEY=replace-me-with-64-hex-chars

# Set to 1 during local development (allows cookies over plain HTTP)
DISPENSER_DEV=1

# Max simultaneous Google handshakes
MINT_CONCURRENCY=64

# Per-mint deadline in seconds
MINT_TIMEOUT_SECONDS=90

# Device profiles directory and default profile
RESOURCES_DIR=resources
DEFAULT_DEVICE=arm64_xxhdpi

# Session lifetime in hours
SESSION_TTL_HOURS=336

# Canonical base URL embedded in minted auth bundles (tokenDispenserUrl)
PUBLIC_URL=https://dispenser.gplaydl.com
